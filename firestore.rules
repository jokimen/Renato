rules_version = '2';

// Default-deny: no admin auth is wired up yet (that's Fase 3). Fase 1 reads
// site content from the local lib/content.ts config, not Firestore.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
